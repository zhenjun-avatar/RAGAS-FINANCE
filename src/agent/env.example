# LLM API keys
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
QWEN_API_KEY=
ANTHROPIC_API_KEY=

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=false
LOG_LEVEL=INFO
# loguru：相对路径相对 src/agent；设为 - 或 none 则只打 stderr 不写文件
LOG_FILE=logs/agent.log

# Generation / embedding
DEFAULT_MODEL=deepseek/deepseek-chat
EMBEDDING_MODEL=text-embedding-v3
# Qwen text-embedding-v3 default vector dim is often 1024; align with Qdrant collection size.
EMBEDDING_DIMENSION=1536
# Qwen/DashScope v3 allows only a few inputs per embeddings request; vectorizer caps at 6. OpenAI can use 64+.
EMBEDDING_BATCH_SIZE=64
# auto | qwen | openai — if you see "Connection error" to dashscope.aliyuncs.com, use: EMBEDDING_PROVIDER=openai
EMBEDDING_PROVIDER=auto
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# PostgreSQL (local: docker compose -f docker-compose.rag.yml up -d  from repo root)
# Compose maps container 5432 -> host 5433 by default so a local Postgres on 5432 does not steal connections.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/rag
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=rag
DB_HOST=127.0.0.1
DB_PORT=5433

# Qdrant (compose defaults to host 6433; override QDRANT_HTTP_PORT when running compose)
QDRANT_HOST=127.0.0.1
QDRANT_PORT=6433
QDRANT_API_KEY=
QDRANT_COLLECTION=rag_nodes
DENSE_BACKEND=qdrant
SPARSE_BACKEND=postgres

# OpenSearch sparse backend（若启用 SPARSE_BACKEND=opensearch，请先准备索引服务与合适 analyzer）
OPENSEARCH_HOST=127.0.0.1
OPENSEARCH_PORT=9200
OPENSEARCH_USER=
OPENSEARCH_PASSWORD=
OPENSEARCH_USE_SSL=false
OPENSEARCH_VERIFY_CERTS=true
OPENSEARCH_TIMEOUT_SECONDS=15
OPENSEARCH_SPARSE_INDEX=rag_nodes_sparse
OPENSEARCH_SPARSE_INDEX_FINANCE=
# sparse：finance=仅财务稀疏索引（须配置 OPENSEARCH_SPARSE_INDEX_FINANCE）；all=财务索引 + OPENSEARCH_SPARSE_INDEX 兜底
OPENSEARCH_SPARSE_SEARCH_SCOPE=finance
# 如已安装中文 analyzer（例如 IK），可设置：
# OPENSEARCH_SPARSE_ANALYZER=ik_max_word
# OPENSEARCH_SPARSE_SEARCH_ANALYZER=ik_smart
OPENSEARCH_SPARSE_ANALYZER=
OPENSEARCH_SPARSE_SEARCH_ANALYZER=

# Retrieval
RAG_PIPELINE_VERSION=node-rag-v1
HIERARCHICAL_GROUP_SIZE=6
RETRIEVE_TOP_K=12
RETRIEVE_CANDIDATE_K=40
SPARSE_TOP_K=30
# include_pipeline_trace 时 retrieval_sparse_hits[].text_preview 最大长度
PIPELINE_TRACE_SPARSE_TEXT_CHARS=800
DENSE_TOP_K=30
CONTEXT_NEIGHBOR_RADIUS=1

# Bocha reranker（documents 为纯文本列表 + model；官方常见模型：bocha-semantic-reranker-cn / bocha-semantic-reranker-en / gte-rerank）
BOCHA_RERANKER_URL=
BOCHA_API_KEY=
BOCHA_RERANKER_MODEL=bocha-semantic-reranker-cn
BOCHA_TIMEOUT_SECONDS=8
BOCHA_TOP_N=12

# Langfuse（须 LANGFUSE_ENABLED=true；数据发往 LANGFUSE_BASE_URL 或 LANGFUSE_HOST 对应实例，请在同一 URL 的 Web UI → Traces 按 trace_id 查找）
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=http://127.0.0.1:3000
# 勿设置 OTEL_SDK_DISABLED=true，否则 SDK 不向 Langfuse 导出

# LangGraph planner
ENABLE_LANGGRAPH_PLANNER=false

# SEC 拉取 submissions / 申报 HTML 时必填可识别 User-Agent（含联系邮箱）
SEC_HTTP_USER_AGENT=your-org-name/1.0 (you@company.com)

# EDGAR .htm 入库：true=Unstructured 分区并在同目录写 .unstructured.json，正文来自 JSON（表格用行级 TABLE | …）；false=内置 HTML 解析
EDGAR_HTML_USE_UNSTRUCTURED=true

# Finance / SEC companyfacts：问答时规则优先路由；歧义时用 LLM 判定是否查 SQL / 检索
FINANCE_SQL_ROUTING_ENABLED=true
FINANCE_SQL_ROUTING_LLM_FALLBACK=true
# true：是否查 SQL 由 LLM 直接判定（跳过规则路由）
FINANCE_LLM_ROUTE_ONLY=false
# 规则同时命中 SQL+RAG 时，再调一次 LLM 精炼（纯叙述题可关 SQL / 限制 facts 行数）
FINANCE_LLM_HYBRID_REFINE=true
# true：用 LLM 生成 FinanceQueryPlan（失败则回退关键词规则）
FINANCE_LLM_SQL_PLANNER_ENABLED=true
# hybrid 问答：用 SQL 返回行的 accn / metric 标签对 RAG 节点重排
FINANCE_SQL_NARROW_RAG_ENABLED=true
# true：池子只保留「命中优先」填满 top_k（命中不足再用高分未命中回填）；false：整池重排命中在前
FINANCE_SQL_NARROW_RAG_STRICT=true

# RAGAS
RAGAS_ENABLED=false
RAGAS_LLM_MODEL=deepseek/deepseek-chat
RAGAS_BATCH_SIZE=20
