# API keys
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
QWEN_API_KEY=
ANTHROPIC_API_KEY=

# Models
DEFAULT_MODEL=deepseek/deepseek-chat

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=True

# Ask API: default top_k when omitted in the request body (generate max 50; vector-search max 20)
ASK_DEFAULT_TOP_K=3
ASK_VECTOR_SEARCH_DEFAULT_TOP_K=3
# Evidence UI: LLM picks answer-aligned verbatim quotes from retrieved passages (substring-verified). Conclusion unchanged.
ASK_EVIDENCE_LLM_EXTRACT_ENABLED=true
ASK_EVIDENCE_LLM_MAX_SOURCES=12
ASK_EVIDENCE_LLM_CHARS_PER_SOURCE=7000
ASK_EVIDENCE_LLM_MAX_QUOTES=3
ASK_EVIDENCE_LLM_MIN_QUOTE_CHARS=40
ASK_EVIDENCE_LLM_MAX_QUOTE_CHARS=1200

# Logging
LOG_LEVEL=INFO

# report/detail/ask_detail_*.json: when true, each rag.evidence item includes text_full (API loads full text from DB when saving reports)
REPORT_DETAIL_FULL_EVIDENCE=false
# Max characters per text_full; 0 = no truncation
REPORT_DETAIL_FULL_EVIDENCE_MAX_CHARS=0
# ask_result_*.json: when true, drop large trace fields and keep a slim summary for debugging (ask_detail still uses full response)
REPORT_ASK_SLIM=true

LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3001
ENABLE_MONITORING=false
MONITORING_RETENTION_DAYS=30

# RAGAS: POST /agent/api/ask/evaluate/pending consumes rag_evaluation_jobs; when disabled, jobs are marked skipped and no Langfuse scores are written
RAGAS_ENABLED=false
RAGAS_LLM_MODEL=deepseek/deepseek-chat
RAGAS_BATCH_SIZE=20

STORAGE_PROVIDER=oss
# OSS (object storage)
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET_NAME=
OSS_ENDPOINT=

# OSS (document storage bucket)
OSS_DOCUMENTS_BUCKET_NAME=
OSS_DOCUMENTS_ENDPOINT=

CORS_ALLOWED_ORIGINS=


## NLS (Alibaba speech / NLP services, if used)
NLS_ACCESS_KEY_ID=
NLS_ACCESS_KEY_SECRET=
NLS_APP_KEY=



# Node RAG stack (docker compose -f docker-compose.rag.yml from repo root; host ports avoid local Postgres/Qdrant clashes)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/rag
DB_HOST=127.0.0.1
DB_PORT=5433
DB_USER=postgres
DB_PASSWORD=
DB_NAME=rag
QDRANT_HOST=127.0.0.1
QDRANT_PORT=6433
# If DashScope embeddings often hit Connection errors locally, switch to OpenAI embeddings
EMBEDDING_PROVIDER=qwen

LANGFUSE_ENABLED=false
BOCHA_RERANKER_URL=https://api.bocha.cn/v1/rerank
BOCHA_API_KEY=
BOCHA_RERANKER_MODEL=gte-rerank

DENSE_BACKEND=qdrant
SPARSE_BACKEND=opensearch

# OpenSearch sparse backend (if SPARSE_BACKEND=opensearch, run an index service and a suitable analyzer first)
OPENSEARCH_HOST=127.0.0.1
OPENSEARCH_PORT=9200
OPENSEARCH_USER=
OPENSEARCH_PASSWORD=
OPENSEARCH_USE_SSL=false
OPENSEARCH_VERIFY_CERTS=true
OPENSEARCH_TIMEOUT_SECONDS=15
OPENSEARCH_SPARSE_INDEX=
# finance: query only OPENSEARCH_SPARSE_INDEX_FINANCE (must be non-empty). exam / all: see comments in config
OPENSEARCH_SPARSE_SEARCH_SCOPE=finance
OPENSEARCH_SPARSE_INDEX_FINANCE=rag_nodes_sparse_finance_v1
# If a Chinese analyzer is installed (e.g. IK), you can set:
# OPENSEARCH_SPARSE_ANALYZER=ik_max_word
# OPENSEARCH_SPARSE_SEARCH_ANALYZER=ik_smart
OPENSEARCH_SPARSE_ANALYZER=
OPENSEARCH_SPARSE_SEARCH_ANALYZER=
#OPENSEARCH_SPARSE_ANALYZER=cjk
#OPENSEARCH_SPARSE_SEARCH_ANALYZER=cjk

FINANCE_SQL_ROUTING_ENABLED=true
# true: SEC facts SQL + hybrid RAG; false: RAG only (still builds evidence_plan / narrative queries and filing_scope_resolver)
# FINANCE_SQL_ROUTING_ENABLED=false
# Comma-separated rag_documents.id values excluded from retrieval per ask (e.g. XBRL companyfacts-only doc 9500)
# RAG_ASK_EXCLUDED_DOCUMENT_IDS=9500
FINANCE_SQL_ROUTING_LLM_FALLBACK=true
ENABLE_LANGGRAPH_PLANNER=false

# Hybrid Q&A: rerank RAG nodes using accn / metric labels from SQL rows
FINANCE_SQL_NARROW_RAG_ENABLED=true
# true: pool keeps “hits first” until top_k is filled (backfill with high-scoring non-hits if needed); false: rerank the whole pool with hits first
FINANCE_SQL_NARROW_RAG_STRICT=true

SEC_HTTP_USER_AGENT=

RETRIEVE_TOP_K=8
RETRIEVE_CANDIDATE_K=24
DENSE_TOP_K=20
CONTEXT_NEIGHBOR_RADIUS=0

EDGAR_HTML_USE_UNSTRUCTURED=true

FINANCE_LLM_HYBRID_REFINE=true
FINANCE_LLM_SQL_PLANNER_ENABLED=true
# mixed_narrative_first only: sql_before_rag | rag_before_sql
MIXED_NARRATIVE_EVIDENCE_ORDER=sql_before_rag
# After first RAG, align SQL rows to RAG top filings (sql_before_rag only; rag_before_sql is already RAG-led)
MIXED_NARRATIVE_SQL_ALIGN_TO_RAG_FILINGS=true

FINANCE_LLM_ROUTE_ONLY=true

# Narrative retrieval: ignore section_role for allowlists / score bonuses (metadata still stored)
NARRATIVE_IGNORE_SECTION_ROLE=true
# Narrative retrieval: ignore leaf_role for scoped-leaf fallback threshold, answerability blocks/bonuses, coverage slots
NARRATIVE_IGNORE_LEAF_ROLE=false

# Narrative retrieval: post-rerank evidence selector
NARRATIVE_POST_RERANK_SELECTOR_ENABLED=true
NARRATIVE_CITATIONABILITY_FILTER_ENABLED=true
NARRATIVE_DEDUPE_ENABLED=true
NARRATIVE_DEDUPE_SIMILARITY_THRESHOLD=0.84
# Multi-facet Bocha rerank for narrative (merge by max score per node); risk_factors → 3 queries by default
NARRATIVE_MULTI_RERANK_ENABLED=true
NARRATIVE_MULTI_RERANK_MAX_QUERIES=3
# Narrative leaf: true = allow all-filings fallback when filing-scoped leaf evidence is weak; false = keep leaves narrowed to finance_accns when set
NARRATIVE_LEAF_ALL_FILINGS=true
